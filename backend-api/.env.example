# Database Configuration
MONGO_URI=mongodb://127.0.0.1:27017/touristdb
# When using Docker, use: mongodb://mongo:27017/touristdb

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_at_least_32_chars

# Email Configuration (for notifications)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# Twilio Configuration (for SMS notifications)
TWILIO_SID=your_twilio_account_sid
TWILIO_AUTH=your_twilio_auth_token
TWILIO_PHONE=+1234567890

# Admin Emails (comma-separated for notifications)
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# Node Environment
NODE_ENV=development
# Use 'production' for deployments

# Server Port
PORT=5000

# External API Keys (for Pune live data)
# Get your API key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Get your API key from: https://gnews.io/
GNEWS_API_KEY=your_gnews_api_key_here
